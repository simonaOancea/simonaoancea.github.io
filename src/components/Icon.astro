---
// Inline SVG icon map. Brand marks are filled; arrows are stroked.
// Adding a social icon = add a path here + allow it in socialSchema.

interface Props {
  name:
    | 'github'
    | 'linkedin'
    | 'x'
    | 'email'
    | 'rss'
    | 'palette'
    | 'arrow-left'
    | 'arrow-up-right';
  size?: number;
}

