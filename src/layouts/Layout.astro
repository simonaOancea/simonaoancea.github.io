---
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import '../styles/global.css';
import Head from '../components/Head.astro';
import SocialHeader from '../components/SocialHeader.astro';
import ThemePicker from '../components/ThemePicker.astro';
import { themes, DEFAULT_THEME } from '../data/themes';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  withBack?: boolean;
}

const { title, description, ogType, withBack = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js" data-theme={DEFAULT_THEME.id} data-scheme={DEFAULT_THEME.scheme}>
  <head>
    <Head title={title} description={description} ogType={ogType} />
    <script is:inline define:vars={{ themes, defaultId: DEFAULT_THEME.id }}>
      // Runs synchronously before first paint: apply the saved theme and flag
      // that JS is available (the html.js class gates scroll-reveal hiding).
      (function () {
        var id = defaultId;
        try {
          var saved = localStorage.getItem('theme');
          if (
            saved &&
            themes.some(function (t) {
              return t.id === saved;
            })
          ) {
            id = saved;
          }
        } catch (e) {
          /* locked-down storage: keep the default theme */
        }
        var entry = themes.filter(function (t) {
          return t.id === id;
        })[0];
        var root = document.documentElement;
        root.setAttribute('data-theme', entry.id);
        root.setAttribute('data-scheme', entry.scheme);
        root.classList.remove('no-js');
        root.classList.add('js');
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', entry.bg);
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="cursor" aria-hidden="true"></div>
    <div class="cursor-follower" aria-hidden="true"></div>

    <div class="bg-shapes" aria-hidden="true">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>

    <SocialHeader withBack={withBack} />

    <main id="main" class="container">
      <slot />
    </main>

    <ThemePicker />

    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
